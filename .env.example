# 数据库配置
DB_URL=jdbc:mysql://localhost:3306/icecream_db?useUnicode=true&characterEncoding=utf8&useSSL=false&serverTimezone=Asia/Shanghai
DB_USERNAME=root
DB_PASSWORD=root

# Redis配置
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# JWT配置
JWT_SECRET=your-256-bit-secret-key-change-this-in-production
JWT_EXPIRATION=86400000

# 文件上传
FILE_UPLOAD_DIR=./uploads

# CORS配置
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8080

# 生产环境数据库（用于Docker）
DATABASE_URL=jdbc:mysql://${DB_HOST:localhost}:${DB_PORT:3306}/${DB_NAME:icecream_prod}?useUnicode=true&characterEncoding=utf8&useSSL=false&serverTimezone=UTC&rewriteBatchedStatements=true
DATABASE_USERNAME=${DATABASE_USERNAME}
DATABASE_PASSWORD=${DATABASE_PASSWORD}